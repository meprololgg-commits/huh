local function checkLineOfSight(spos, vec, currentdist, targetModel)
	local myCharacter = LocalPlayer.Character
	if not myCharacter then return false end
	params2.FilterDescendantsInstances = {myCharacter}

	local currentPos = spos
	local remainingDist = currentdist

	while remainingDist > 0 do
		local rayResult = workspace:Raycast(currentPos + (vec * 0.01), vec * remainingDist, params2)
		if not rayResult then return true end

		local hitPart = rayResult.Instance
		local hitPos = rayResult.Position

		if hitPart == targetModel or hitPart:IsDescendantOf(targetModel) then
			return true
		end

		local p1 = hitPart.Parent
		local p2 = p1 and p1.Parent

		local isIgnored = (hitPart.Transparency >= 0.5)
			or hitPart.Name == "Handle"
			or string.sub(hitPart.Name, 1, 6) == "Effect"
			or hitPart.CanCollide == false
			or (p1 and (p1:IsA("Hat") or p1:IsA("Accessory") or p1:IsA("Tool")))
			or (p1 and p1:FindFirstChild("Armor"))
			or (p2 and p2:FindFirstChild("Armor"))

		if isIgnored then
			local traveled = (hitPos - currentPos).Magnitude
			remainingDist = remainingDist - traveled
			currentPos = hitPos
			table.insert(params2.FilterDescendantsInstances, hitPart)
		else
			return false
		end
	end
	return false
end

local function getPartUnderCrosshair()
	local camCFrame = Camera.CFrame
	local camPos = camCFrame.Position
	local lookDir = camCFrame.LookVector

	local highestDot = 0.975
	local bestPart = nil
	local enemiesFolder = workspace:FindFirstChild("Enemies")

	if not enemiesFolder then return nil end

	for _, object in enemiesFolder:GetChildren() do
		if not object:IsA("Model") then continue end

		local humanoid = object:FindFirstChildOfClass("Humanoid")
		if not humanoid or humanoid.Health <= 0 then continue end

		local head = object:FindFirstChild("Head")
		if head then
			local partPos = head.Position
			local dist = (partPos - camPos).Magnitude

			local dirToTarget = (partPos - camPos).Unit
			local dotProd = lookDir:Dot(dirToTarget)

			if dotProd > highestDot then
				if checkLineOfSight(camPos, dirToTarget, dist, object) then
					highestDot = dotProd
					bestPart = head
				end
			end
		end
	end
	return bestPart
end

-- Main Aimbot Loop
Connection = RunService.RenderStepped:Connect(function()
	if not isAimbotEnabled then return end

	local myCharacter = LocalPlayer.Character
	if not myCharacter then return end

	local humanoid = myCharacter:FindFirstChildOfClass("Humanoid")
	if humanoid and humanoid.Health <= 0 then return end

	if not myCharacter:FindFirstChildOfClass("Tool") then return end

	local targetPart = getPartUnderCrosshair()
	if targetPart then
		local targetModel = targetPart.Parent
		local targetPos = targetPart.Position
		local targetCFrame = targetPart.CFrame

		-- Prediction
		if usePrediction then
			local rootPart = targetModel:FindFirstChild("HumanoidRootPart")
			if rootPart then
				local velocity = rootPart.AssemblyLinearVelocity
				local predictedPos = targetPos + velocity * predictionAmount
				targetPos = predictedPos

				-- Keep head rotation
				targetCFrame = CFrame.new(predictedPos) * targetCFrame.Rotation
			end
		end

		local targetAimCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
		Camera.CFrame = Camera.CFrame:Lerp(targetAimCFrame, trackingSensitivity)
	end
end)
